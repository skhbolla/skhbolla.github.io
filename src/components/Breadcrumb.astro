---
interface Props {
  category: string;
  categoryUrl: string;
  title: string;
  slug?: string;
}

const { category, categoryUrl, title, slug } = Astro.props;

// Build segments if slug is nested
const segments = slug ? slug.split('/') : [];
const isNested = segments.length > 1;

// The intermediate directory paths
const intermediateBreadcrumbs = isNested
  ? segments.slice(0, -1).map((segment, index) => {
      const path = segments.slice(0, index + 1).join('/');
      return {
        label: segment.replace(/-/g, ' '),
        url: `${categoryUrl}/${path}/`,
      };
    })
  : [];
---

<nav class="breadcrumb" id="breadcrumb-nav" aria-label="Breadcrumb">
  <span class="label glyph" aria-hidden="true">↳</span>
  <a href="/" class="label">Home</a>
  
  <span class="label divider" aria-hidden="true">/</span>
  {slug ? (
    <>
      <a href={categoryUrl} class="label">{category}</a>
      
      {intermediateBreadcrumbs.map((trail) => (
        <span class="label divider" aria-hidden="true">/</span>
        <a href={trail.url} class="label">{trail.label}</a>
      ))}
      
      <span class="label divider" aria-hidden="true">/</span>
      <span class="label current" aria-current="page">{title}</span>
    </>
  ) : (
    <span class="label current" aria-current="page">{category}</span>
  )}
</nav>

<script>
  const setupObserver = () => {
    const el = document.getElementById("breadcrumb-nav");
    if (!el) return;

    // threshold: [1] triggers when the element is less than 100% visible
    const observer = new IntersectionObserver(
      ([e]) => el.classList.toggle("is-stuck", e.intersectionRatio < 1),
      { threshold: [1], rootMargin: "0px 0px 0px 0px" },
    );
    observer.observe(el);
  };

  setupObserver();
  document.addEventListener("astro:page-load", setupObserver);
</script>

<style>
  .breadcrumb {
    margin-bottom: var(--space-1);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: nowrap;
    min-width: 0;

    position: sticky;
    top: -1px;
    z-index: 40;

    background-color: var(--color-bg);
    padding: var(--space-2) var(--space-3);
    padding-top: calc(var(--space-2) + 1px); /* Compensate for top: -1px */

    border-radius: var(--radius-sm);
    border: var(--border-thin) solid transparent; /* No visible border at rest to avoid layout jump */

    transition:
      background-color var(--transition-base),
      border-color var(--transition-base),
      border-radius var(--transition-base),
      box-shadow var(--transition-base);
  }

  .breadcrumb.is-stuck {
    backdrop-filter: blur(var(--blur-md));
    background-color: var(--color-paper-glass);

    /* Paper shadow and border on stick */
    box-shadow: var(--shadow-paper);
    border: var(--border-thin) solid var(--color-card-border);
  }

  /* Match Mobile Edge-to-Edge */
  @media (max-width: 48rem) {
    .breadcrumb {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .breadcrumb.is-stuck {
      border-radius: 0;
    }
  }

  .breadcrumb .label {
    font-size: var(--text-micro);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    line-height: 1;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (max-width: 90rem) {
    .breadcrumb .label {
      font-size: var(--text-xs);
    }
  }

  .breadcrumb .glyph {
    color: var(--color-border);
    font-size: var(--text-xs); /* Slightly larger than label micro size */
  }

  .breadcrumb a.label {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    flex-shrink: 0; /* Category name shouldn't shrink */
  }

  .breadcrumb a.label:hover {
    color: var(--color-text);
  }

  .breadcrumb .divider {
    flex-shrink: 0;
  }

  .breadcrumb .current {
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0; /* Allows flex child to truncate properly */
    display: block;
  }
</style>
