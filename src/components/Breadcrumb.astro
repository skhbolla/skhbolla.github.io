---
interface Props {
  category: string;
  categoryUrl: string;
  title: string;
  slug?: string;
}

const { category, categoryUrl, title, slug } = Astro.props;

// Build segments if slug is nested
const segments = slug ? slug.split("/") : [];
const isNested = segments.length > 1;

// The intermediate directory paths
const intermediateBreadcrumbs = isNested
  ? segments.slice(0, -1).map((segment, index) => {
      const path = segments.slice(0, index + 1).join("/");
      return {
        label: segment.replace(/-/g, " "),
        url: `${categoryUrl}/${path}/`,
      };
    })
  : [];

function truncate(str: string) {
  return str.length > 15 ? str.substring(0, 15).trim() + "..." : str;
}
---

<nav class="breadcrumb" id="breadcrumb-nav" aria-label="Breadcrumb">
  <span class="label glyph" aria-hidden="true">↳</span>
  <a href="/" class="label">Home</a>

  <span class="label divider" aria-hidden="true">/</span>
  {
    slug ? (
      <Fragment>
        <a href={categoryUrl} class="label" title={category}>
          {truncate(category)}
        </a>

        {intermediateBreadcrumbs.map((trail) => (
          <Fragment>
            <span class="label divider" aria-hidden="true">
              /
            </span>
            <a href={trail.url} class="label" title={trail.label}>
              {truncate(trail.label)}
            </a>
          </Fragment>
        ))}

        <span class="label divider" aria-hidden="true">
          /
        </span>
        <span class="label current" aria-current="page" title={title}>
          {truncate(title)}
        </span>
      </Fragment>
    ) : (
      <span class="label current" aria-current="page" title={category}>
        {truncate(category)}
      </span>
    )
  }
</nav>

<script>
  let docClickListener: (e: MouseEvent) => void;
  let resizeListener: () => void;

  const setupBreadcrumb = () => {
    const el = document.getElementById("breadcrumb-nav");
    if (!el) return;

    // Sticky observer
    const observer = new IntersectionObserver(
      ([e]) => el.classList.toggle("is-stuck", e.intersectionRatio < 1),
      { threshold: [1], rootMargin: "0px 0px 0px 0px" },
    );
    observer.observe(el);

    // Expandable check
    const currentEl = el.querySelector(".current");
    const checkExpandable = () => {
      // Temporarily remove expanded class to measure natural collapsed width
      const wasExpanded = el.classList.contains("is-expanded");
      if (wasExpanded) el.classList.remove("is-expanded");

      const isOverflowing =
        el.scrollWidth > el.clientWidth ||
        (currentEl && currentEl.scrollWidth > currentEl.clientWidth);

      el.classList.toggle("is-expandable", !!isOverflowing);

      if (wasExpanded) el.classList.add("is-expanded");
    };

    if (resizeListener) {
      window.removeEventListener("resize", resizeListener);
    }
    resizeListener = () => checkExpandable();
    window.addEventListener("resize", resizeListener, { passive: true });

    // Initial check
    checkExpandable();

    // Expand/Collapse logic
    el.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const isExpanded = el.classList.contains("is-expanded");
      const isExpandable = el.classList.contains("is-expandable");
      const link = target.closest("a");

      if (!isExpanded) {
        if (isExpandable) {
          // If we have hidden content, clicking anywhere expands it instead of navigating
          if (link) e.preventDefault();
          el.classList.add("is-expanded");
        }
      } else {
        // If expanded and clicking a link, let the browser navigate
        if (link) return;
        el.classList.remove("is-expanded");
      }
    });

    if (docClickListener) {
      document.removeEventListener("click", docClickListener);
    }

    docClickListener = (e: MouseEvent) => {
      if (!el.contains(e.target as Node)) {
        el.classList.remove("is-expanded");
      }
    };

    document.addEventListener("click", docClickListener);
  };

  setupBreadcrumb();
  document.addEventListener("astro:page-load", setupBreadcrumb);
</script>

<style>
  .breadcrumb {
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    column-gap: var(--space-3);
    row-gap: var(--space-2);

    /* Default: 1 line */
    flex-wrap: nowrap;
    overflow: hidden;
    min-width: 0;

    position: sticky;
    top: var(--space-n-pixel);
    z-index: 40;

    background-color: var(--color-bg);
    padding: var(--space-3) var(--space-4);
    padding-top: calc(var(--space-3) + var(--space-pixel));

    border-radius: var(--radius-sm);
    border: var(--border-thin) solid transparent;

    transition:
      background-color var(--transition-base),
      border-color var(--transition-base),
      border-radius var(--transition-base),
      box-shadow var(--transition-base);
  }

  /* Only show pointer when there's actually hidden content to reveal */
  .breadcrumb.is-expandable:not(.is-expanded) {
    cursor: pointer;
  }

  .breadcrumb.is-expandable:not(.is-expanded) a.label {
    cursor: pointer;
  }

  /* Expanded state */
  .breadcrumb.is-expanded {
    flex-wrap: wrap;
    cursor: default;
  }

  .breadcrumb.is-stuck {
    backdrop-filter: blur(var(--blur-md));
    background-color: var(--color-paper-glass);
    box-shadow: var(--shadow-paper);
    border: var(--border-thin) solid var(--color-card-border);
  }

  @media (max-width: 48rem) {
    .breadcrumb {
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .breadcrumb.is-stuck {
      border-radius: 0;
    }
  }

  .breadcrumb .label {
    font-size: var(--text-xs);
    line-height: var(--leading-xs);
    letter-spacing: var(--tracking-normal);
    margin: 0;
    
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .breadcrumb .glyph {
    color: var(--color-border);
    font-size: var(--text-xs);
    line-height: var(--leading-xs);
    flex-shrink: 0;
  }

  .breadcrumb a.label {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    flex-shrink: 0; /* Keep links from shrinking when collapsed */
  }

  .breadcrumb a.label:hover {
    color: var(--color-text);
  }

  .breadcrumb .divider {
    flex-shrink: 0;
  }

  .breadcrumb .current {
    color: var(--color-text);
    display: block;
    /* When collapsed, let the current item take the overflow hit */
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .breadcrumb.is-expanded .current {
    overflow: visible;
    text-overflow: clip;
  }
</style>
