---
// A small static SVG diagram, used inside the .mdx sample post to show how
// a diagram component drops into prose. No JS, no client directive needed —
// it's just markup, so it renders at build time like everything else.
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
const fields = ["x", "y", "lock", "pad"];
---

<figure class="cache-line">
  <svg
    viewBox="0 0 480 90"
    role="img"
    aria-label="A 64-byte cache line split into four 16-byte fields: x, y, lock, pad"
  >
    {
      fields.map((label, i) => (
        <g transform={`translate(${i * 120}, 0)`}>
          <rect
            x="4"
            y="4"
            width="112"
            height="60"
            rx="2"
            fill="none"
            stroke="var(--color-border)"
          />
          <text
            x="60"
            y="38"
            text-anchor="middle"
            font-family="var(--font-label)"
            font-size="14"
            fill="var(--color-text)"
          >
            {label}
          </text>
        </g>
      ))
    }
    <text
      x="240"
      y="84"
      text-anchor="middle"
      font-family="var(--font-label)"
      font-size="10"
      fill="var(--color-text-muted)"
    >
      one 64-byte cache line
    </text>
  </svg>
  {caption && <figcaption class="meta">{caption}</figcaption>}
</figure>

<style>
  .cache-line {
    margin-block: var(--space-4);
    margin-inline: 0;
    width: 100%;
  }
  .cache-line svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .cache-line figcaption {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    margin-top: var(--space-1);
  }
</style>
