<!--
  CodeEnhance: progressively enhances <pre class="astro-code"> blocks inside
  .prose with:
    1. A toolbar above the block showing the language label (left) and a
       copy-to-clipboard button (right).
    2. The toolbar + pre share a rounded card shape so they read as one unit.

  Styles live in <style is:global> so they can target dynamically-inserted
  DOM nodes and override the scoped .astro-code styles from global.css.
-->

<script>
  const enhance = () => {
    // Only target prose code blocks (not standalone inline code)
    const blocks =
      document.querySelectorAll<HTMLElement>(".prose .astro-code");

    blocks.forEach((pre) => {
      // Guard: don't double-process on SPA navigations
      if (pre.closest(".code-block")) return;

      const lang = pre.getAttribute("data-language") ?? "";

      // ── Build wrapper ──────────────────────────────────────────────────────
      const wrapper = document.createElement("div");
      wrapper.className = "code-block";

      // ── Build toolbar ──────────────────────────────────────────────────────
      const toolbar = document.createElement("div");
      toolbar.className = "code-toolbar";
      toolbar.setAttribute("aria-hidden", "true");

      if (lang) {
        const label = document.createElement("span");
        label.className = "code-lang";
        label.textContent = lang;
        toolbar.appendChild(label);
      } else {
        // spacer so the copy button stays right-aligned when there's no label
        toolbar.appendChild(document.createElement("span"));
      }

      const copyBtn = document.createElement("button");
      copyBtn.className = "code-copy";
      copyBtn.setAttribute("aria-label", "Copy code to clipboard");
      copyBtn.textContent = "Copy";
      toolbar.appendChild(copyBtn);

      // ── Insert into DOM ────────────────────────────────────────────────────
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(toolbar);
      wrapper.appendChild(pre);

      // ── Copy handler ───────────────────────────────────────────────────────
      copyBtn.addEventListener("click", async () => {
        // Prefer the <code> text content to avoid invisible Shiki span noise
        const text =
          pre.querySelector("code")?.innerText ?? pre.innerText ?? "";
        try {
          await navigator.clipboard.writeText(text);
          copyBtn.textContent = "Copied!";
        } catch {
          copyBtn.textContent = "Failed";
        }
        setTimeout(() => {
          copyBtn.textContent = "Copy";
        }, 2000);
      });
    });
  };

  enhance();
  document.addEventListener("astro:page-load", enhance);
</script>

<style is:global>
  /* ─── Code block card wrapper ─────────────────────────────────────────────
     The .code-block div wraps .astro-code so we can attach a visible toolbar
     above the code panel without touching the Shiki output.
  ──────────────────────────────────────────────────────────────────────────── */

  .code-block {
    /* Reset any margins global.css might add via .prose pre */
    margin-block: var(--space-4);
  }

  /* ── Toolbar ──────────────────────────────────────────────────────────────*/
  .code-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-code-bg);
    border: var(--border-thin) solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    padding: var(--space-nano) var(--space-3);
    gap: var(--space-3);
  }

  /* Language label */
  .code-lang {
    font-family: var(--font-code);
    font-size: var(--text-micro);
    color: var(--color-text-muted);
    text-transform: lowercase;
    letter-spacing: var(--tracking-wide);
    /* Allow ellipsis on very narrow screens */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  /* Copy button */
  .code-copy {
    font-family: var(--font-label);
    font-size: var(--text-micro);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .code-copy:hover {
    color: var(--color-accent);
  }

  /* ── Pre overrides when inside wrapper ────────────────────────────────────*/
  .code-block .astro-code {
    /* Merge visually with toolbar above */
    margin: 0 !important;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg) !important;
    border: var(--border-thin) solid var(--color-border) !important;
    border-top: none !important;
  }

  /* Pre loses its top border-radius to merge cleanly with the toolbar */
  .code-block pre {
    margin: 0;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }
</style>
