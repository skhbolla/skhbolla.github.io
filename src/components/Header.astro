---
import ThemeToggle from "./ThemeToggle.astro";

const { pathname } = Astro.url;

// Helper to check if a route is active.
// We use startsWith to keep categories active when viewing individual posts,
// but exact match for home to avoid matching everything.
function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

const navLinks = [
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
];
---

<header class="site-header responsive-padding">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-accent">[</span> srikanth.bolla <span class="brand-accent">]</span>
    </a>
    <div class="nav-container">
      <nav aria-label="Primary">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={isActive(link.href) ? "active" : ""}
              data-active={isActive(link.href) ? "true" : "false"}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <div class="toggle-wrapper">
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    /* Removed border to allow the header to flow naturally into the body */
  }

  .header-inner {
    max-width: var(--measure);
    margin-inline: auto;
    padding-top: var(--space-8); /* Increased top space for tablets */
    padding-bottom: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    font-family: var(--font-label);
    font-size: var(--text-xl);
    line-height: var(--leading-xl);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: var(--tracking-brand);
    transition: color var(--transition-base);
  }

  .brand-accent {
    color: var(--color-accent);
    opacity: 0.8;
    transition: opacity var(--transition-base);
  }

  .brand:hover {
    color: var(--color-accent);
  }
  
  .brand:hover .brand-accent {
    opacity: 1;
  }

  .nav-container {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  nav {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
  }

  nav a {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    line-height: var(--leading-xs);
    color: var(--color-text);
    background: var(--btn-bg);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: var(--border-thin) solid var(--btn-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--btn-shadow);
    text-transform: uppercase;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--size-nav-btn);
    box-sizing: border-box;
  }

  nav a:hover {
    border-color: var(--btn-border-hover);
  }

  nav a:active,
  nav a.active {
    background: var(--btn-bg-active);
    box-shadow: var(--btn-shadow-active);
  }

  .toggle-wrapper {
    display: flex;
    align-items: center;
    padding-left: var(--space-4);
    border-left: var(--border-thin) solid var(--color-border);
  }

  /* Responsive layout for tiny screens */
  @media (max-width: 35rem) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
      padding-block: var(--space-4);
    }

    .brand {
      font-size: var(--text-base);
      line-height: var(--leading-base);
    }

    .nav-container {
      width: 100%;
      justify-content: space-between;
    }
  }

  /* Large screens: more vertical breathing */
  @media (min-width: 64rem) {
    .header-inner {
      padding-top: var(--space-12); /* Even more top space for laptops */
      padding-bottom: var(--space-6);
    }
  }
</style>
