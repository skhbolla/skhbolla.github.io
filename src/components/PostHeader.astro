---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  subtitle?: string;
  author?: string;
  date: Date;
  formattedDate: string;
  heroImage?: ImageMetadata;
}

const { title, subtitle, author, date, formattedDate, heroImage } = Astro.props;
---

<header class="post-header">
  <div class="meta">
    {author && <span>{author}</span>}
    {author && <span class="bullet">•</span>}
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h1>{title}</h1>
  {subtitle && <h2 class="post-subtitle">{subtitle}</h2>}
  <div class="header-divider">╌╌╌╌</div>
  {
    heroImage && (
      <div class="hero-container">
        <Image
          src={heroImage}
          alt=""
          class="hero-image"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )
  }
</header>

<style>
  .post-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 0;
  }

  .meta {
    margin-top: 0;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .bullet {
    margin-inline: var(--space-1);
    opacity: 0.4;
  }

  h1 {
    margin-top: 0;
    margin-bottom: var(--space-2);
    font-size: var(--text-2xl); /* 36px */
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: 500;
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: auto;
    max-width: 100%;
  }

  .post-subtitle {
    margin-top: 0;
    margin-bottom: 0;
    font-size: var(--text-sm); /* 14px */
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .header-divider {
    font-family: var(--font-label);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-header-divider);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    opacity: 0.4;
  }

  .hero-container {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
    width: 100%;
  }

  .hero-image {
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-paper);
    border: var(--border-thin) solid var(--color-card-border);
  }
</style>
