---
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle?: string;
  author?: string;
  formattedDate: string;
  heroImage?: any;
}

const { title, subtitle, author, formattedDate, heroImage } = Astro.props;
---

<header class="post-header">
  <p class="meta">
    {author}
    <span class="bullet">|</span>
    {formattedDate}
  </p>
  <h1>{title}</h1>
  {subtitle && <h2 class="post-subtitle">{subtitle}</h2>}
  <div class="header-divider">╌╌╌╌</div>
  {
    heroImage && (
      <div class="hero-container">
        <Image src={heroImage} alt="" class="hero-image" loading="eager" fetchpriority="high" />
      </div>
    )
  }
</header>

<style>
  .post-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 0;
  }

  .meta {
    margin-top: 0;
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-family: var(--font-label);
    font-size: 0.6875rem; /* Exactly matches breadcrumb */
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .bullet {
    margin-inline: var(--space-1);
    opacity: 0.5;
  }

  h1 {
    margin-top: 0;
    margin-bottom: var(--space-2);
    font-size: var(--text-2xl); /* 36px */
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .post-subtitle {
    margin-top: 0;
    margin-bottom: 0;
    font-size: var(--text-sm); /* 14px */
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .header-divider {
    font-family: var(--font-label);
    color: var(--color-text-muted);
    letter-spacing: 0.2em;
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
    opacity: 0.5;
  }

  .hero-container {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .hero-image {
    max-width: 80%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.05),
      0 2px 4px -2px rgba(0, 0, 0, 0.05),
      0 0 0 1px rgba(0, 0, 0, 0.02);
  }
</style>
