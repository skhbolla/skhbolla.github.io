---
import type { ListItem } from "../types";
import PostCard from "./cards/PostCard.astro";
import SeriesCard from "./cards/SeriesCard.astro";

interface Props {
  items: ListItem[];
}

const { items } = Astro.props;
---

<ul class="post-grid">
  {
    items.map((item) => {
      if (item.type === "series" || item.type === "collection") {
        return <SeriesCard item={item} />;
      } else {
        return <PostCard {...item} />;
      }
    })
  }
</ul>

<style>
  .post-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  /* Wider gap on desktop */
  @media (min-width: 64rem) {
    .post-grid {
      gap: var(--space-8);
    }
  }
</style>
