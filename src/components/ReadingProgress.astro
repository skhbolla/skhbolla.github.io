---

<!-- Reading progress bar — 2px line at very top of viewport -->
<div
  id="reading-progress"
  role="progressbar"
  aria-label="Reading progress"
  aria-hidden="true"
>
</div>

<!-- Back-to-top button — appears after 400px of scroll -->
<button id="back-to-top" aria-label="Back to top" title="Back to top">↑</button>

<script>
  const setup = () => {
    const bar = document.getElementById("reading-progress");
    const btn = document.getElementById("back-to-top");
    if (!bar || !btn) return;

    const onScroll = () => {
      const scrollTop = window.scrollY;
      const maxScroll =
        document.documentElement.scrollHeight - window.innerHeight;
      const pct =
        maxScroll > 0 ? Math.min((scrollTop / maxScroll) * 100, 100) : 0;

      bar.style.width = `${pct}%`;
      btn.classList.toggle("is-visible", scrollTop > 400);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // Initialise on mount
    onScroll();
  };

  setup();
  document.addEventListener("astro:page-load", setup);
</script>

<style>
  /* ─── Reading progress ──────────────────────────────────────────────────── */
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: var(--border-thick);
    background: var(--color-accent);
    z-index: 9999;
    pointer-events: none;
    transition: width 0.1s linear;
  }

  @media (prefers-reduced-motion: reduce) {
    #reading-progress {
      transition: none;
    }
  }

  /* ─── Back-to-top ───────────────────────────────────────────────────────── */
  #back-to-top {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);

    /* Size & shape — matches nav buttons */
    width: var(--size-nav-btn);
    height: var(--size-nav-btn);
    padding: 0;
    box-sizing: border-box;

    /* Typography */
    font-family: var(--font-label);
    font-size: var(--text-icon);
    

    /* Theming — reuses the flat retro button system */
    color: var(--color-text);
    background: var(--btn-bg);
    border: var(--border-thin) solid var(--btn-border);
    border-radius: var(--radius-sm);
    box-shadow: var(--btn-shadow);
    cursor: pointer;

    /* Layout */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 100;

    /* Entry/exit animation */
    opacity: 0;
    visibility: hidden;
    transform: translateY(var(--space-3));
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast),
      border-color var(--transition-fast),
      /* delay visibility OFF so it fades out before disappearing */ visibility
        0s var(--transition-fast);
  }

  #back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast),
      border-color var(--transition-fast),
      visibility 0s; /* no delay when becoming visible */
  }

  #back-to-top:hover {
    border-color: var(--btn-border-hover);
  }

  #back-to-top:active {
    background: var(--btn-bg-active);
    box-shadow: var(--btn-shadow-active);
  }

  /* Smaller offset on tiny screens to avoid overlapping content */
  @media (max-width: 35rem) {
    #back-to-top {
      bottom: var(--space-4);
      right: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #back-to-top,
    #back-to-top.is-visible {
      transition: none;
    }
  }
</style>
