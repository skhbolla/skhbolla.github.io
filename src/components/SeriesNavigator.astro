---
import { getHierarchyRegistry } from "../utils/hierarchy";

interface Props {
  seriesPosts?: any[];
  slug?: string;
  categoryUrl: string;
}

const { seriesPosts, slug, categoryUrl } = Astro.props;

const registry = seriesPosts && seriesPosts.length > 0
  ? getHierarchyRegistry(seriesPosts[0].collection, seriesPosts)
  : new Map();
---

{seriesPosts && seriesPosts.length > 1 && (
  <div class="series-navigator">
    <div class="series-nav-title">
      <span>Series Contents</span>
    </div>
    <ul class="series-nav-list">
      {seriesPosts.map((p) => {
        const node = registry.get(p.id);
        const prefix = node?.displayNumber ? `${node.displayNumber}. ` : "";
        
        return (
          <li class={p.id === slug ? "active" : ""}>
            {p.id === slug ? (
              <span>
                {prefix && <span class="nav-number">{prefix}</span>}
                {p.data.title}{" "}
                <span class="current-badge">(You are here)</span>
              </span>
            ) : (
              <a href={`${categoryUrl}/${p.id}/`}>
                {prefix && <span class="nav-number">{prefix}</span>}
                {p.data.title}
              </a>
            )}
          </li>
        );
      })}
    </ul>
  </div>
)}

<style>
  .series-navigator {
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-6);
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
    line-height: var(--leading-sm);
  }

  @media (min-width: 48rem) {
    .series-navigator {
      padding: var(--space-6) var(--space-8);
      margin-top: var(--space-12);
      margin-bottom: var(--space-12);
    }
  }

  .series-nav-title {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    line-height: var(--leading-xs);
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: var(--border-thin) dotted var(--color-border);
    padding-bottom: var(--space-3);
    margin-bottom: var(--space-4);
    letter-spacing: var(--tracking-wide);
  }

  .series-nav-list {
    margin: 0;
    padding-left: 0;
    list-style: none;
  }

  .nav-number {
    font-variant-numeric: tabular-nums;
    margin-right: var(--space-2);
  }

  .series-nav-list li {
    
    margin-bottom: var(--space-2);
  }
  .series-nav-list li.active {
    color: var(--color-nav-active);
    font-weight: 500;
  }

  .series-nav-list a {
    color: var(--color-link);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .series-nav-list a:hover {
    color: var(--color-link-hover);
  }

  .current-badge {
    font-family: var(--font-label);
    font-size: var(--text-micro);
    line-height: var(--leading-micro);
    color: var(--color-text-muted);
    margin-left: var(--space-3);
    text-transform: uppercase;
  }
</style>
