---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;

// Only h2 and h3 are meaningful in a ToC
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  tocHeadings.length > 1 && (
    <aside class="toc-panel" aria-label="Table of contents">
      <div class="toc-inner">
        <p class="toc-title">On this page</p>
        <nav>
          <ul class="toc-list">
            {tocHeadings.map((h) => (
              <li class={`toc-item toc-h${h.depth}`}>
                <a href={`#${h.slug}`} class="toc-link" data-slug={h.slug}>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>
  )
}

<script>
  const setupToc = () => {
    const links =
      document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (!links.length) return;

    let currentSlug: string | null = null;

    const setActive = (slug: string) => {
      if (slug === currentSlug) return;
      currentSlug = slug;
      links.forEach((l) => l.classList.remove("is-active"));
      document
        .querySelector<HTMLAnchorElement>(`.toc-link[data-slug="${slug}"]`)
        ?.classList.add("is-active");
    };

    const slugs = [...links].map((l) => l.dataset.slug!);
    const headingEls = slugs
      .map((s) => document.getElementById(s))
      .filter((el): el is HTMLElement => el !== null);

    if (!headingEls.length) return;

    // Scroll-position approach — more reliable than IntersectionObserver
    // for fine-grained heading tracking.
    const onScroll = () => {
      // Offset: sticky header (~80px) + some breathing room
      const threshold = window.scrollY + 120;
      let active = slugs[0];

      for (const el of headingEls) {
        if (el.offsetTop <= threshold) {
          active = el.id;
        }
      }
      setActive(active);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll(); // set initial state
  };

  setupToc();
  document.addEventListener("astro:page-load", setupToc);
</script>

<style>
  /* Hidden on anything smaller than a wide desktop */
  .toc-panel {
    display: none;
  }

  @media (min-width: 80rem) {
    .toc-panel {
      display: block;
      /* Sits in the second grid column of .post-layout-grid */
      min-width: 0;
    }

    .toc-inner {
      position: sticky;
      /* Below the fixed header + scroll-padding + a little breathing room */
      top: calc(var(--scroll-padding) + var(--space-3));
      max-height: calc(100vh - var(--scroll-padding) - var(--space-8));
      overflow-y: auto;
      /* Thin, unobtrusive scrollbar */
      scrollbar-width: thin;
      scrollbar-color: var(--color-border) transparent;
      padding-right: var(--space-1);
    }

    .toc-title {
      font-family: var(--font-label);
      font-size: var(--text-micro);
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--color-text-muted);
      margin: 0 0 var(--space-3) 0;
      padding-bottom: var(--space-2);
      border-bottom: var(--border-thin) solid var(--color-border);
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .toc-item {
      margin-bottom: 0;
    }

    /* h3 items are indented under their parent h2 */
    .toc-h3 {
      padding-left: var(--space-3);
    }

    .toc-link {
      display: block;
      font-family: var(--font-body);
      font-size: var(--text-xs);
      line-height: var(--leading-snug);
      color: var(--color-text-muted);
      text-decoration: none;
      padding: var(--space-nano) var(--space-2);
      border-left: var(--border-thick) solid transparent;
      transition:
        color var(--transition-fast),
        border-color var(--transition-fast);
    }

    .toc-link:hover {
      color: var(--color-text);
      border-left-color: var(--color-border);
    }

    .toc-link.is-active {
      color: var(--color-accent);
      border-left-color: var(--color-accent);
      font-weight: 500;
    }
  }
</style>
