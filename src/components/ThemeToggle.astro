<button id="theme-toggle" aria-label="Toggle color theme">◐</button>

<style>
  #theme-toggle {
    font-family: var(--font-label);
    font-size: var(--text-icon); /* Replaced 1.1rem */
    color: var(--color-text);
    background: var(--btn-bg);
    border: var(--border-thin) solid var(--btn-border); /* Replaced 1px */
    border-radius: var(--radius-sm);
    box-shadow: var(--btn-shadow);
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--size-nav-btn); /* Replaced 1.75rem */
    height: var(--size-nav-btn); /* Replaced 1.75rem */
    padding: 0;
    line-height: 1;
    box-sizing: border-box;
  }
  
  #theme-toggle:hover {
    border-color: var(--btn-border-hover);
  }

  #theme-toggle:active {
    background: var(--btn-bg-active);
    box-shadow: var(--btn-shadow-active);
  }
</style>

<script>
  // Append new theme names here as you build them — nothing else about
  // this component needs to change. Color values for each name live in
  // src/styles/themes.css as [data-theme="name"] blocks.
  const themes = ['light', 'dark'];

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme ?? 'light';
    const next = themes[(themes.indexOf(current) + 1) % themes.length];
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
