---
import type { SeriesItem, CollectionItem } from "../../types";

type Props = {
  item: SeriesItem | CollectionItem;
};

const { item } = Astro.props;
---

<li class="post-item">
  <div class="series-stack">
    <div class="back-card" />
    <a href={item.url} class="post-card front-card">
      <div class="card-meta">
        <span class="category-badge series-badge">
          {item.type === "series" ? "Series" : "Collection"}
        </span>
        <span class="post-count">
          {item.postCount} {item.type === "series" ? "parts" : "posts"}
        </span>
      </div>
      <h3 class="card-title">{item.title}</h3>
      <p class="card-description">{item.description}</p>
      <div class="card-footer">
        <span class="read-link">
          Open {item.type === "series" ? "Series" : "Collection"} <span class="arrow">↳</span>
        </span>
      </div>
    </a>
  </div>
</li>

<style>
  .post-item {
    margin: 0;
    padding: 0;
    position: relative;
    flex: 0 1 var(--card-size);
    width: 100%;
    max-width: var(--card-size);
  }

  .series-stack {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.35;
  }

  .back-card {
    position: absolute;
    inset: 0;
    background: var(--color-paper);
    border: var(--border-thin) solid var(--color-card-border);
    box-shadow: var(--shadow-paper);
    border-radius: var(--radius-sm);
    transform: translate(var(--space-stack), calc(-1 * var(--space-stack))) rotate(1.5deg);
    z-index: 1;
    transition: transform var(--transition-base);
  }

  .front-card {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    background: var(--color-paper);
    padding: var(--space-6) var(--space-6) var(--space-4);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-paper);
    border: var(--border-thin) solid var(--color-card-border);
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  .series-stack:hover .front-card {
    transform: translateY(calc(var(--space-pixel) * -3)) rotate(var(--transform-rotate-hover));
    border-color: var(--color-series-badge);
    box-shadow: var(--shadow-paper-hover);
  }

  .series-stack:hover .back-card {
    transform: translate(calc(var(--space-stack) * 1.75), calc(-1 * var(--space-stack) * 1.75)) rotate(3deg);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
    width: 100%;
  }

  .category-badge {
    font-family: var(--font-label);
    font-size: var(--text-micro);
    line-height: var(--leading-micro);
    background: var(--color-code-bg);
    color: var(--color-tag);
    border: var(--border-thin) solid transparent;
    padding: var(--space-nano) var(--space-micro);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    transition:
      background var(--transition-base),
      border-color var(--transition-base),
      color var(--transition-base);
  }

  .series-badge {
    background: var(--color-series-badge);
    color: var(--color-bg);
    border-color: var(--color-series-badge);
  }

  .post-count {
    font-family: var(--font-label);
    font-size: var(--text-micro);
    line-height: var(--leading-micro);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .card-title {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-base);
    font-weight: 500;
    margin-top: 0;
    margin-bottom: var(--space-2);
    transition: color var(--transition-base);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .series-stack:hover .card-title {
    color: var(--color-accent);
  }

  .card-description {
    font-size: var(--text-sm);
    line-height: var(--leading-sm);
    color: var(--color-text);
    margin: 0;
    margin-bottom: var(--space-3);
    flex-grow: 1;
    text-align: justify;
    hyphens: auto;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: auto;
  }

  .read-link {
    font-family: var(--font-label);
    font-size: var(--text-xs);
    line-height: var(--leading-xs);
    color: var(--color-text-muted);
    transition: color var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: var(--space-nano);
  }

  .series-stack:hover .read-link {
    color: var(--color-accent);
  }

  .arrow {
    transition: transform var(--transition-base);
  }

  .series-stack:hover .arrow {
    transform: translate(calc(var(--space-pixel) * 2), calc(var(--space-pixel) * 2));
  }

  /* Tablet Overrides */
  @media (max-width: 64rem) and (min-width: 40rem) {
    .post-item {
      flex: 0 1 var(--card-size-md);
      max-width: var(--card-size-md);
    }
    .back-card {
      transform: translate(calc(var(--space-stack) * 0.75), calc(-1 * var(--space-stack) * 0.75)) rotate(1.5deg);
    }
    .post-card {
      padding: var(--space-4) var(--space-4) var(--space-3);
    }
    .card-title {
      font-size: var(--text-sm);
      line-height: var(--leading-sm);
    }
    .card-description {
      -webkit-line-clamp: 3;
    }
  }

  /* Mobile Overrides */
  @media (max-width: 40rem) {
    .post-item {
      flex: 0 1 var(--card-size-sm);
      max-width: var(--card-size-sm);
    }
    .back-card {
      transform: translate(calc(var(--space-stack) * 0.75), calc(-1 * var(--space-stack) * 0.75)) rotate(1.5deg);
    }
    .series-stack:hover .front-card {
      transform: translateY(calc(var(--space-pixel) * -2)) rotate(var(--transform-rotate-hover));
      border-color: var(--color-accent);
      box-shadow: var(--shadow-paper-hover);
    }
    .series-stack:hover .back-card {
      transform: translate(calc(var(--space-stack) * 1.25), calc(-1 * var(--space-stack) * 1.25)) rotate(3deg);
    }
    .post-card {
      padding: var(--space-4) var(--space-4) var(--space-3);
    }
    .card-meta {
      margin-bottom: var(--space-3);
    }
    .category-badge {
      padding: var(--space-nano) var(--space-micro);
    }
    .card-title {
      font-size: var(--text-sm);
      line-height: var(--leading-sm);
      margin-bottom: var(--space-2);
    }
    .card-description {
      font-size: var(--text-xs);
      line-height: var(--leading-xs);
      margin-bottom: var(--space-3);
      -webkit-line-clamp: 3;
    }
    .read-link {
      font-size: var(--text-micro);
      line-height: var(--leading-micro);
      gap: var(--space-nano);
    }
  }
</style>
