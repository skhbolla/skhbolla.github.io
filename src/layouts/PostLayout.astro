---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PostHeader from "../components/PostHeader.astro";
import SeriesNavigator from "../components/SeriesNavigator.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import { formatDate } from "../utils/formatDate";

interface Props {
  title: string;
  subtitle?: string;
  author?: string;
  heroImage?: any;
  description: string;
  date: Date;
  category: string;
  categoryUrl: string;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
  slug?: string;
  seriesPosts?: any[];
}

const {
  title,
  subtitle,
  author,
  heroImage,
  description,
  date,
  category,
  categoryUrl,
  tags,
  headings,
  slug,
  seriesPosts,
} = Astro.props;

const formattedDate = formatDate(date);
---

<BaseLayout title={title} description={description}>
  <ReadingProgress />

  <div class="paper-wrapper">
    <Breadcrumb
      category={category}
      categoryUrl={categoryUrl}
      title={title}
      slug={slug}
    />
    <article class="paper-overlay prose">
      <PostHeader
        title={title}
        subtitle={subtitle}
        author={author}
        date={date}
        formattedDate={formattedDate}
        heroImage={heroImage}
      />
      <SeriesNavigator
        seriesPosts={seriesPosts}
        slug={slug}
        categoryUrl={categoryUrl}
      />
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .paper-wrapper {
    min-width: 0;
    max-width: var(--measure);
    margin-inline: auto;
    width: 100%;
  }

  .paper-overlay {
    background: var(--color-paper);
    padding: var(--space-8) var(--space-7);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-paper);
    border: var(--border-thin) solid var(--color-card-border);
    margin-bottom: var(--space-8);
    position: relative;
  }

  /* Large tablets */
  @media (max-width: 64rem) {
    .paper-overlay {
      padding: var(--space-7) var(--space-6);
    }
  }

  /* Medium tablets */
  @media (max-width: 56rem) {
    .paper-overlay {
      padding: var(--space-6) var(--space-5);
    }
  }

  /* Small tablets / phones — edge-to-edge, drop the card metaphor */
  @media (max-width: 48rem) {
    .paper-overlay {
      padding: var(--space-6) var(--space-5);
      border-radius: 0;
      border: none;
      box-shadow: none;
      margin-bottom: 0;
    }
  }
</style>

<style is:global>
  @media (max-width: 48rem) {
    body {
      background: var(--color-paper);
    }
  }
</style>
