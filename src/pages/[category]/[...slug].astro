---
import { getCollection } from "astro:content";
import { getHierarchyRegistry } from "../../utils/hierarchy";
import { CATEGORY_MAP } from "../../utils/categories";
import type { AnyPost, DirectoryProps, PostProps } from "../../types";
import CategoryView from "../../components/views/CategoryView.astro";
import PostView from "../../components/views/PostView.astro";

type Props = PostProps | DirectoryProps;

// ─── Static path generation ───────────────────────────────────────────────────

export async function getStaticPaths() {
  const paths: {
    params: { category: string; slug: string | undefined };
    props: Props;
  }[] = [];

  for (const [category, meta] of Object.entries(CATEGORY_MAP)) {
    const posts = (await getCollection(
      meta.collection,
      ({ data }) => !data.draft,
    )) as AnyPost[];

    // Collect every unique subdirectory path at all nesting depths
    const directories = new Set<string>();
    for (const post of posts) {
      const parts = post.id.split("/");
      parts.pop(); // strip filename
      for (let depth = 1; depth <= parts.length; depth++) {
        directories.add(parts.slice(0, depth).join("/"));
      }
    }

    // Category root index (slug = undefined)
    paths.push({
      params: { category, slug: undefined },
      props: { type: "directory", meta, posts, activeDir: "" },
    });

    // Subdirectory index pages
    for (const dir of directories) {
      paths.push({
        params: { category, slug: dir },
        props: {
          type: "directory",
          meta,
          posts: posts.filter((p) => p.id.startsWith(dir + "/")),
          activeDir: dir,
        },
      });
    }

    // Individual post pages
    for (const post of posts) {
      paths.push({
        params: { category, slug: post.id },
        props: { type: "post", meta, post },
      });
    }
  }

  return paths;
}

// ─── Page Controller Logic ────────────────────────────────────────────────────

const { category } = Astro.params;
const props = Astro.props as Props;

let seriesPosts: AnyPost[] = [];

if (props.type === "post") {
  // Resolve sibling posts in the same directory (the series)
  const pathParts = props.post.id.split("/");
  pathParts.pop(); // strip filename
  const seriesPath = pathParts.join("/");

  const allPosts = (await getCollection(
    props.meta.collection,
    ({ data }) => !data.draft,
  )) as AnyPost[];
  const registry = getHierarchyRegistry(props.meta.collection, allPosts);

  if (seriesPath) {
    seriesPosts = allPosts
      .filter((p) => {
        const pParts = p.id.split("/");
        pParts.pop();
        return pParts.join("/") === seriesPath;
      })
      .sort((a, b) => {
        const aHier = registry.get(a.id)?.hierarchy || [];
        const bHier = registry.get(b.id)?.hierarchy || [];

        const minLen = Math.min(aHier.length, bHier.length);
        for (let i = 0; i < minLen; i++) {
          if (aHier[i] !== bHier[i]) {
            return aHier[i] - bHier[i];
          }
        }
        
        if (aHier.length !== bHier.length) {
          if (aHier.length > 0 && bHier.length > 0) {
            return aHier.length - bHier.length;
          }
        }

        if (aHier.length === 0 && bHier.length === 0) {
          return a.data.date.valueOf() - b.data.date.valueOf();
        }

        if (aHier.length > 0 && bHier.length === 0) return -1;
        if (aHier.length === 0 && bHier.length > 0) return 1;

        return 0;
      });
  }
  
  props.displayNumber = registry.get(props.post.id)?.displayNumber;
}
---

{
  props.type === "post" ? (
    <PostView {...props} category={category} seriesPosts={seriesPosts} />
  ) : (
    <CategoryView {...props} category={category} />
  )
}
