---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { CATEGORY_MAP } from '../../utils/categories';

export function getStaticPaths() {
  return Object.keys(CATEGORY_MAP).map((category) => {
    return {
      params: { category },
      props: { meta: CATEGORY_MAP[category] },
    };
  });
}

const { category } = Astro.params;
const { meta } = Astro.props;

const posts = (await getCollection(meta.collection, ({ data }: any) => !data.draft)).sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title={meta.title} description={meta.description}>
  <div class="prose">
    <h1>{meta.indexTitle}</h1>
    <p class="meta">{meta.description}</p>
    <PostList posts={posts} basePath={`/${category}`} />
  </div>
</BaseLayout>
