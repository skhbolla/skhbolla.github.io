---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import MetricsTable from "../components/MetricsTable.astro";
import { getCollection } from "astro:content";
import { CATEGORY_MAP } from "../utils/categories";

import PostList from "../components/PostList.astro";
import type { ListItem } from "../components/PostList.astro";

const categoryEntries = Object.entries(CATEGORY_MAP);

const allPosts = await Promise.all(
  categoryEntries.map(([_, meta]) =>
    getCollection(meta.collection, ({ data }) => !data.draft),
  ),
);

const collectionItems: ListItem[] = categoryEntries.map(([slug, meta], index) => ({
  type: "collection",
  id: slug,
  title: meta.title,
  description: meta.description,
  postCount: allPosts[index].length,
  url: `/${slug}/`,
}));

const flatPosts = allPosts.flat();
const collectionsCount = categoryEntries.length;
---

<BaseLayout title="Home">
  <div class="prose">
    <h1>Three threads, one site</h1>
    <p>
      This is where I write about three things: how computers actually work
      underneath the abstractions (<a href="/mech-sympathy/"
        >mechanical sympathy</a
      >), the algorithms that sit on top of them (<a href="/dsa/">dsa</a>), and
      architecting scalable distributed applications (<a href="/system-design/"
        >system design</a
      >).
    </p>
    <p>Pick a path above, or just start reading.</p>
  </div>
  
  <MetricsTable posts={flatPosts} collectionsCount={collectionsCount} />

  <div class="posts-grid-container">
    <PostList items={collectionItems} />
  </div>
  
  <Footer />
</BaseLayout>

<style>
  .posts-grid-container {
    max-width: var(--measure-grid);
    margin-inline: auto;
    margin-top: var(--space-7);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 64rem) {
    .posts-grid-container {
      margin-top: var(--space-8);
      margin-bottom: var(--space-hero);
    }
  }
</style>
